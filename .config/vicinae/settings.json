// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "imports": [],
   "close_on_focus_loss": false,
   "consider_preedit": false,
   "pop_to_root_on_close": true,
   "escape_key_behavior": "navigate_back",
   "favicon_service": "twenty",
   "keybinding": "default",
   "pixmap_cache_mb": 50,
   "search_files_in_root": false,
   "font": {
      "normal": {
         "family": "Maple Mono",
         "size": 10
      }
   },
   "theme": {
      "light": {
         "name": "vicinae-light",
         "icon_theme": "auto"
      },
      "dark": {
         "name": "matugen",
         "icon_theme": "auto"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 0.6,
      "client_side_decorations": {
         "enabled": true,
         "rounding": 10,
         "border_width": 2
      },
      "size": {
         "width": 770,
         "height": 480
      },
      "blur": {
         "enabled": true
      },
      "compact_mode": {
         "enabled": false
      },
      "layer_shell": {
         "layer": "overlay",
         "keyboard_interactivity": "exclusive",
         "enabled": true
      }
   },
   "keybinds": {
      "action.copy": "control+shift+C",
      "action.copy-name": "control+shift+.",
      "action.copy-path": "control+shift+,",
      "action.dangerous-remove": "control+shift+X",
      "action.duplicate": "control+D",
      "action.edit": "control+E",
      "action.edit-secondary": "control+shift+E",
      "action.move-down": "control+shift+ARROWDOWN",
      "action.move-up": "control+shift+ARROWUP",
      "action.new": "control+N",
      "action.open": "control+O",
      "action.pin": "control+shift+P",
      "action.refresh": "control+R",
      "action.remove": "control+X",
      "action.save": "control+S",
      "open-search-filter": "control+P",
      "open-settings": "control+,",
      "toggle-action-panel": "control+B"
   },
   "favorites": [
      "@lufimio/audio-management:connect-wh-ch720n"
   ],
   "fallbacks": [
      "files:search"
   ],
   "providers": {
      "@AntonNiklasson/store.raycast.lorem-ipsum": {
         "preferences": {
            "action": "pasteAndCopy"
         },
         "entrypoints": {
            "ai-generate": {
               "enabled": false
            }
         }
      },
      "@DanielSinclair/store.raycast.base64": {
         "entrypoints": {
            "decode": {
               "alias": "b64d"
            },
            "encode": {
               "alias": "b64e"
            }
         }
      },
      "@Melvynx/store.raycast.qrcode-generator": {
         "entrypoints": {
            "selection": {
               "enabled": false
            }
         }
      },
      "@biknandy/store.raycast.quick-notes": {
         "preferences": {
            "fileLocation": "/home/lufimio/Documents/Other/Obsidian/TestNotesIg"
         }
      },
      "@dagimg-dot/store.vicinae.player-pilot": {
         "entrypoints": {
            "player-pilot": {
               "alias": "mpris"
            }
         }
      },
      "@gbgk/glyph-search": {
         "enabled": false,
         "entrypoints": {
            "index": {
               "alias": "sym"
            }
         }
      },
      "@gebeto/store.raycast.translate": {
         "entrypoints": {
            "instant-translate-copy": {
               "enabled": false
            },
            "instant-translate-paste": {
               "enabled": false
            },
            "instant-translate-view": {
               "enabled": false
            }
         }
      },
      "@kud/store.raycast.espanso": {
         "entrypoints": {
            "add-match": {
               "enabled": false
            },
            "index": {
               "enabled": false
            }
         }
      },
      "@lufimio/gpu-screen-recorder": {
         "preferences": {
            "open-after-save-replay": false,
            "open-after-stop-recording": false
         },
         "entrypoints": {
            "save-instant-replay": {
               "alias": "clip"
            }
         }
      },
      "@lufimio/playerctl": {
         "enabled": false
      },
      "@mblode/store.raycast.cyberchef": {
         "enabled": false,
         "entrypoints": {
            "convert-area": {
               "enabled": true
            },
            "convert-distance": {
               "enabled": true
            },
            "convert-mass": {
               "enabled": true
            },
            "convert-speed": {
               "enabled": true
            },
            "csv-to-json": {
               "enabled": true
            },
            "find-replace": {
               "enabled": true
            },
            "generate-qr-code": {
               "enabled": true
            },
            "json-to-csv": {
               "enabled": true
            },
            "pad-lines": {
               "enabled": true
            }
         }
      },
      "@mmazzarolo/store.raycast.unicode-symbols": {
         "preferences": {
            "dataSet": "full",
            "gridItemSize": "small",
            "primaryAction": "paste",
            "searchResultLimitStr": "250"
         },
         "entrypoints": {
            "index": {
               "alias": "sym"
            }
         }
      },
      "@sovereign/store.vicinae.hypr-keybinds": {
         "preferences": {
            "keybindsConfigPath": "/home/lufimio/.config/hypr/hypr/keybinds.conf"
         }
      },
      "applications": {
         "preferences": {
            "defaultAction": "focus",
            "paths": [
               "/home/lufimio/.local/share/applications",
               "/var/lib/flatpak/exports/share/applications",
               "/usr/share/applications"
            ]
         },
         "entrypoints": {
            "code-oss": {
               "alias": "vscode"
            }
         }
      },
      "clipboard": {
         "preferences": {
            "encryption": false,
            "monitoring": true
         },
         "entrypoints": {
            "clear-history": {
               "enabled": false
            },
            "history": {
               "alias": "cl"
            }
         }
      },
      "core": {
         "entrypoints": {
            "inspect-local-storage": {
               "enabled": true
            },
            "prune-memory": {
               "enabled": false
            },
            "search-emojis": {
               "alias": "em"
            },
            "sponsor": {
               "enabled": false
            }
         }
      },
      "scripts": {
         "preferences": {
            "customDirs": [
               "/home/lufimio/.config/vicinae/scripts/"
            ]
         }
      },
      "system": {
         "entrypoints": {
            "browse-apps": {
               "enabled": true,
               "preferences": {
                  "showHidden": false
               }
            }
         }
      }
   }
}